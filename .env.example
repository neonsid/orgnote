# Convex
NEXT_PUBLIC_CONVEX_URL=
NEXT_PUBLIC_CONVEX_SITE_URL=
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Expo (apps/mobile) — copy into apps/mobile/.env.local (see apps/mobile/.env.example)
