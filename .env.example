# Convex
CONVEX_DEPLOY_KEY=
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=
NEXT_PUBLIC_CONVEX_SITE_URL=
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Better Auth
BETTER_AUTH_SECRET=
# BETTER_AUTH_URL is auto-set to http://localhost:3000 in dev, set this for production

# Prisma Postgres
# - Dev: Use direct PostgreSQL URL (postgres:// or postgresql://)
# - Prod: Use Prisma Accelerate URL (prisma://)
DATABASE_URL=

# Direct PostgreSQL URL for migrations (only needed in production with Accelerate)
# This should be the direct postgresql:// URL, not the prisma:// Accelerate URL
DIRECT_DATABASE_URL=

# Google OAuth (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
