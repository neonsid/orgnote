{
  "name": "goldfish",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "predev": "convex dev --until-success",
    "dev": "npm-run-all --parallel dev:web dev:backend",
    "dev:web": "pnpm --filter @goldfish/web dev",
    "dev:mobile": "pnpm --filter @goldfish/mobile start",
    "dev:backend": "convex dev",
    "build": "pnpm --filter @goldfish/web build",
    "start": "pnpm --filter @goldfish/web start",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "eslint apps/web convex --ignore-pattern \"convex/_generated/**\"",
    "lint:fix": "eslint apps/web convex --ignore-pattern \"convex/_generated/**\" --fix",
    "typecheck": "pnpm run --parallel typecheck:web typecheck:mobile",
    "typecheck:web": "pnpm --filter @goldfish/web typecheck",
    "typecheck:mobile": "pnpm --filter @goldfish/mobile typecheck",
    "test:bookmark-parse": "pnpm --filter @goldfish/web test:bookmark-parse"
  },
  "devDependencies": {
    "@convex-dev/eslint-plugin": "^1.1.1",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "convex": "^1.32.0",
    "dotenv": "^17.3.1",
    "eslint": "^9.39.2",
    "eslint-config-next": "16.1.6",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "lint-staged": "^16.3.0",
    "npm-run-all2": "^8.0.4",
    "oxfmt": "^0.16.0",
    "prettier": "^3.8.1",
    "shadcn": "^3.8.5",
    "typescript": "^5.9.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "@tailwindcss/oxide"
    ],
    "overrides": {
      "react": "19.1.0",
      "react-dom": "19.1.0",
      "react-native-screens": "4.16.0",
      "react-native-worklets": "0.5.1"
    }
  },
  "dependencies": {
    "react-native-webview": "13.15.0"
  }
}
