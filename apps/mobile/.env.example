# Same Convex deployment as the web app (Convex Dashboard → Settings → Deployment URL)
EXPO_PUBLIC_CONVEX_URL=

# Clerk: use the DEVELOPMENT publishable key (pk_test_...) for local dev, Expo Go, and
# Expo web (http://localhost:8081). Production keys (pk_live_...) only work on orgnote.store.
# Clerk Dashboard → select Development instance → API Keys.
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=

# Sign in with Google (native dev/production builds — required for Clerk `AuthView` on iOS/Android)
# Omit these to fall back to in-app browser SSO (same flow as Expo Go).
# Clerk Dashboard → User & authentication → SSO → Google → "Use custom credentials"
# plus Google Cloud OAuth clients:
# https://clerk.com/docs/expo/guides/configure/auth-strategies/sign-in-with-google
#
# IMPORTANT: EXPO_PUBLIC_CLERK_GOOGLE_WEB_CLIENT_ID must be your *Web application* OAuth client ID
# (used as server/client token audience), NOT the Android-only or iOS-only client ID.
# EXPO_PUBLIC_CLERK_GOOGLE_WEB_CLIENT_ID=
# EXPO_PUBLIC_CLERK_GOOGLE_IOS_CLIENT_ID=
# EXPO_PUBLIC_CLERK_GOOGLE_ANDROID_CLIENT_ID=
# For plugin / iOS callback URL scheme (derived from iOS client id):
# EXPO_PUBLIC_CLERK_GOOGLE_IOS_URL_SCHEME=
